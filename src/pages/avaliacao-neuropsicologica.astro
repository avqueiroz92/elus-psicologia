---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site, whatsappLink } from "../config/site";

const indications = [
  {
    title: "Atenção e memória",
    icon: "🧠",
    description:
      "Esquecimentos frequentes, desatenção, dificuldade de organização, planejamento ou concentração.",
  },
  {
    title: "Aprendizagem e desempenho",
    icon: "📖",
    description:
      "Dificuldades escolares, leitura, escrita, raciocínio, compreensão ou rendimento acadêmico.",
  },
  {
    title: "TEA, TDAH e neurodivergência",
    icon: "∞",
    description:
      "Compreensão de aspectos cognitivos, emocionais e comportamentais em pessoas neurodivergentes.",
  },
  {
    title: "Saúde emocional",
    icon: "♡",
    description:
      "Avaliação de aspectos emocionais que podem influenciar atenção, comportamento e desempenho.",
  },
  {
    title: "Orientação para famílias",
    icon: "👥",
    description:
      "Compreensão do perfil da pessoa avaliada e orientações para família, escola e outros profissionais.",
  },
];

const steps = [
  {
    number: "01",
    title: "Entrevista inicial",
    icon: "💬",
    description:
      "Conversa para compreender a história, as queixas, o contexto e os objetivos da avaliação.",
  },
  {
    number: "02",
    title: "Aplicação de instrumentos",
    icon: "📋",
    description:
      "Utilização de instrumentos psicológicos e neuropsicológicos adequados à demanda apresentada.",
  },
  {
    number: "03",
    title: "Análise integrada",
    icon: "📊",
    description:
      "Integração dos resultados com entrevistas, observações clínicas e informações relevantes.",
  },
  {
    number: "04",
    title: "Devolutiva e relatório",
    icon: "📄",
    description:
      "Devolutiva clara, orientações e entrega de documento psicológico conforme as normas da profissão.",
  },
];

const faqs = [
  {
    question: "A avaliação neuropsicológica dá diagnóstico?",
    answer:
      "A avaliação pode contribuir para hipóteses diagnósticas e para a compreensão do funcionamento cognitivo, emocional e comportamental. A conclusão depende da análise técnica do caso e pode envolver encaminhamentos complementares quando necessário.",
  },
  {
    question: "Quantas sessões são necessárias?",
    answer:
      "A quantidade de encontros varia conforme a demanda, idade, objetivos da avaliação e instrumentos necessários. Essa estimativa é alinhada após a entrevista inicial.",
  },
  {
    question: "A avaliação é feita apenas com crianças?",
    answer:
      "Não. A avaliação neuropsicológica pode ser realizada com crianças, adolescentes e adultos, sempre considerando a demanda apresentada e a indicação técnica.",
  },
  {
    question: "A avaliação pode ser online?",
    answer:
      "Algumas etapas podem ocorrer online, conforme avaliação técnica, demanda e instrumentos necessários. A adequação da modalidade é analisada caso a caso.",
  },
  {
    question: "Preciso me preparar para a avaliação?",
    answer:
      "Não é necessário estudar ou treinar antes da avaliação. O mais importante é comparecer descansado, levar informações relevantes e, quando houver, documentos ou relatórios anteriores.",
  },
  {
    question: "O relatório pode ser usado na escola ou com outros profissionais?",
    answer:
      "O documento psicológico pode auxiliar no diálogo com família, escola e outros profissionais, respeitando os limites éticos, técnicos e a finalidade da avaliação.",
  },
];
---

<BaseLayout
  title="Avaliação Neuropsicológica | Elus Psicologia"
  description="Avaliação neuropsicológica com escuta acolhedora e responsabilidade técnica para compreender funções cognitivas, emocionais e comportamentais."
>
  <main class="pt-20">
    <section class="container-elus grid items-center gap-12 py-16 md:grid-cols-[0.95fr_1.05fr] md:py-24">
      <div>
        <p class="mb-5 inline-flex rounded-full border border-[#e8ded6] bg-white px-4 py-2 text-sm font-medium text-[#bfa5ed]">
          Avaliação Neuropsicológica
        </p>

        <h1 class="max-w-3xl text-5xl font-normal leading-tight tracking-tight text-[#174442] md:text-6xl">
          Compreender para cuidar com mais clareza e propósito<span class="text-[#f4b3e1]">.</span>
        </h1>

        <div class="mt-5 h-3 w-32 rounded-full border-b-2 border-[#f4b3e1]"></div>

        <p class="mt-8 max-w-2xl text-base leading-8 text-[#6f7774] md:text-lg">
          A avaliação neuropsicológica investiga funções cognitivas, emocionais e
          comportamentais para compreender dificuldades, potencialidades e orientar
          intervenções mais adequadas.
        </p>

        <div class="mt-9 flex flex-col gap-4 sm:flex-row">
          <a
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-full bg-[#338d83] px-7 py-4 text-center text-sm font-semibold text-white shadow-lg shadow-[#338d83]/20 transition hover:bg-[#185c58]"
          >
            Quero saber mais
          </a>

          <a
            href="#como-funciona"
            class="rounded-full border border-[#338d83]/50 bg-white px-7 py-4 text-center text-sm font-semibold text-[#338d83] transition hover:bg-[#f3eeea]"
          >
            Como funciona
          </a>
        </div>

        <div class="mt-12 grid gap-5 text-sm text-[#5d6865] sm:grid-cols-3">
          <div class="flex items-center gap-3">
            <span class="text-2xl text-[#338d83]">♢</span>
            <span>Sigilo e ética profissional</span>
          </div>

          <div class="flex items-center gap-3 border-[#e8ded6] sm:border-l sm:pl-5">
            <span class="text-2xl text-[#338d83]">□</span>
            <span>Instrumentos adequados</span>
          </div>

          <div class="flex items-center gap-3 border-[#e8ded6] sm:border-l sm:pl-5">
            <span class="text-2xl text-[#338d83]">♡</span>
            <span>Devolutiva clara e acolhedora</span>
          </div>
        </div>
      </div>

      <div class="soft-shadow relative flex min-h-[520px] items-center justify-center overflow-hidden rounded-[3rem] bg-[#f7f1ec] p-8">
        <div class="absolute right-[-80px] top-[-80px] h-64 w-64 rounded-full border border-[#338d83]/20"></div>
        <div class="absolute bottom-[-60px] left-[-40px] h-52 w-52 rounded-full bg-[#f4b3e1]/18"></div>

        <div class="relative z-10 flex h-[420px] w-[420px] items-center justify-center rounded-[2.5rem] bg-white/75 p-8 backdrop-blur-sm">
          <img
            src="/icone-elus.png"
            alt="Ícone da marca Elus Psicologia"
            class="h-auto w-full max-w-[360px] object-contain"
            loading="eager"
          />
        </div>
      </div>
    </section>

    <section class="border-y border-[#e8ded6] bg-[#fbf8f5] py-20">
      <div class="container-elus">
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-sm font-bold uppercase tracking-[0.22em] text-[#338d83]">
            Para quem é indicada?
          </p>

          <h2 class="mt-4 text-4xl font-normal leading-tight text-[#174442] md:text-5xl">
            Quando a avaliação neuropsicológica pode ser importante?
          </h2>

          <div class="mx-auto mt-4 h-1 w-16 rounded-full bg-[#f4b3e1]"></div>
        </div>

        <div class="mt-12 grid gap-5 md:grid-cols-5">
          {indications.map((item) => (
            <article class="card-border soft-shadow rounded-[1.75rem] bg-white p-6 text-center">
              <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-[#d7ebe8] text-3xl text-[#338d83]">
                {item.icon}
              </div>

              <h3 class="mt-6 text-xl font-normal leading-tight text-[#174442]">
                {item.title}
              </h3>

              <p class="mt-4 text-sm leading-7 text-[#6f7774]">
                {item.description}
              </p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="como-funciona" class="bg-white py-20">
      <div class="container-elus">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-sm font-bold uppercase tracking-[0.22em] text-[#338d83]">
            Como funciona?
          </p>

          <h2 class="mt-4 text-4xl font-normal text-[#174442] md:text-5xl">
            O processo de avaliação
          </h2>

          <div class="mx-auto mt-4 h-1 w-16 rounded-full bg-[#f4b3e1]"></div>
        </div>

        <div class="mt-14 grid gap-5 md:grid-cols-4">
          {steps.map((step) => (
            <article class="card-border rounded-[1.75rem] bg-white p-7 text-center shadow-sm">
              <span class="mx-auto flex h-11 w-11 items-center justify-center rounded-full bg-[#338d83] text-sm font-bold text-white">
                {step.number}
              </span>

              <div class="mx-auto mt-7 flex h-16 w-16 items-center justify-center rounded-full bg-[#fbf8f5] text-3xl">
                {step.icon}
              </div>

              <h3 class="mt-6 text-xl font-normal text-[#174442]">
                {step.title}
              </h3>

              <p class="mt-4 text-sm leading-7 text-[#6f7774]">
                {step.description}
              </p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-[#fbf8f5] py-20">
      <div class="container-elus grid items-center gap-10 md:grid-cols-[0.95fr_1.05fr]">
        <div class="relative">
          <div class="overflow-hidden rounded-[2rem] bg-[#f3eeea] soft-shadow">
            <img
              src="/jessica-albuquerque.jpg"
              alt="Jéssica Albuquerque Vasconcelos, psicóloga e neuropsicóloga"
              class="h-full min-h-[520px] w-full object-cover object-top"
              loading="lazy"
            />
          </div>

          <div class="absolute -bottom-8 -left-6 hidden max-w-[170px] rounded-full bg-white/95 p-6 text-center text-sm leading-6 text-[#6f7774] shadow-lg md:block">
            <span class="block text-2xl text-[#338d83]">♡</span>
            Cuidado que acolhe e orienta.
          </div>
        </div>

        <div>
          <p class="text-sm font-bold uppercase tracking-[0.22em] text-[#338d83]">
            Profissional responsável
          </p>

          <h2 class="mt-4 text-4xl font-normal leading-tight text-[#174442] md:text-5xl">
            Avaliação conduzida por quem integra técnica e sensibilidade.
          </h2>

          <p class="mt-7 text-base leading-8 text-[#6f7774]">
            Jéssica Albuquerque Vasconcelos é psicóloga clínica e neuropsicóloga,
            com experiência no atendimento de adultos, adolescentes, famílias e pessoas
            neurodivergentes.
          </p>

          <p class="mt-4 text-base leading-8 text-[#6f7774]">
            Sua atuação integra escuta acolhedora, orientação parental e responsabilidade
            técnica, respeitando a singularidade de cada pessoa avaliada.
          </p>

          <ul class="mt-7 space-y-3 text-sm leading-7 text-[#6f7774]">
            <li class="flex gap-3">
              <span class="mt-1 text-[#338d83]">●</span>
              Pós-graduação em Neuropsicologia.
            </li>
            <li class="flex gap-3">
              <span class="mt-1 text-[#338d83]">●</span>
              Formação em ABA e experiência com TEA, TDAH e pessoas neurodivergentes.
            </li>
            <li class="flex gap-3">
              <span class="mt-1 text-[#338d83]">●</span>
              Escuta acolhedora, ética profissional e orientação parental.
            </li>
            <li class="flex gap-3">
              <span class="mt-1 text-[#338d83]">●</span>
              Devolutiva cuidadosa para apoiar próximos caminhos.
            </li>
          </ul>

          <a
            href="/sobre-jessica"
            class="mt-8 inline-flex rounded-full border border-[#338d83]/50 bg-white px-7 py-4 text-sm font-semibold text-[#338d83] transition hover:bg-[#f3eeea]"
          >
            Conhecer a trajetória da Jéssica
          </a>
        </div>
      </div>
    </section>

    <section class="bg-white py-20">
      <div class="container-elus">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-sm font-bold uppercase tracking-[0.22em] text-[#338d83]">
            Dúvidas frequentes
          </p>

          <h2 class="mt-4 text-4xl font-normal text-[#174442] md:text-5xl">
            Perguntas comuns
          </h2>

          <div class="mx-auto mt-4 h-1 w-16 rounded-full bg-[#f4b3e1]"></div>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl gap-4 md:grid-cols-2">
          {faqs.map((faq) => (
            <details class="rounded-[1.25rem] border border-[#e8ded6] bg-white p-5 shadow-sm">
              <summary class="cursor-pointer list-none font-semibold text-[#174442]">
                {faq.question}
              </summary>

              <p class="mt-4 text-sm leading-7 text-[#6f7774]">
                {faq.answer}
              </p>
            </details>
          ))}
        </div>
      </div>
    </section>
    <section class="bg-white pb-20">
  <div class="container-elus">
    <div class="relative overflow-hidden rounded-[2rem] bg-[#338d83] p-9 text-white md:p-12">
      <div class="absolute -left-16 -top-16 h-52 w-52 rounded-full border border-white/20"></div>
      <div class="absolute -right-16 -bottom-16 h-56 w-56 rounded-full border border-white/20"></div>

      <div class="relative flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
        <div>
          <h2 class="max-w-2xl text-4xl font-normal leading-tight">
            Dê o primeiro passo para mais compreensão e bem-estar.
          </h2>

          <p class="mt-3 max-w-xl text-white/85">
            Entre em contato para tirar dúvidas sobre a avaliação e verificar disponibilidade de horários.
          </p>
        </div>

        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 rounded-full bg-white px-8 py-4 text-sm font-bold text-[#338d83] transition hover:bg-[#f3eeea]"
        >
          💬 Agendar conversa
        </a>
      </div>
    </div>
  </div>
</section>
  </main>
</BaseLayout>